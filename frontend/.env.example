# Frontend .env example for LAN/mobile access
# ------------------------------------------------
# Copy this file to .env.local and set the correct IP address of your machine
# Find your LAN IP: run `ipconfig` (Windows) or `ip addr` (Linux/Mac)
#
# Example:
# VITE_API_URL=http://192.168.1.100:3001/api
#
# Leave empty to use localhost (default for local development)
VITE_API_URL=
