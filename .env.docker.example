# ─────────────────────────────────────────────────────────────
# Docker Compose environment — copy thành .env, sửa lại giá trị
#   cp .env.docker.example .env
# ─────────────────────────────────────────────────────────────

# ── Database (MariaDB container) ─────────────────────────────
DB_NAME=ketoan
DB_USER=ketoan_app
# KHÔNG dùng ký tự '@' ':' '/' '?' '#' '&' trong password
# (parseDbUrl của backend hỗ trợ URL-encode, nhưng để an toàn cứ tránh).
DB_PASSWORD=replace-with-strong-password
DB_ROOT_PASSWORD=replace-with-strong-root-password

# ── App ──────────────────────────────────────────────────────
# Sinh ngẫu nhiên 128 ký tự hex:
#   openssl rand -hex 64
JWT_SECRET=replace-with-openssl-rand-hex-64

# Bootstrap admin (TUỲ CHỌN — có thể bỏ trống).
#
# Mặc định: cứ để trống. Lần đầu mở `http://<ip>:3001` frontend sẽ tự hiện
# trang "Khởi tạo hệ thống lần đầu" để bạn đặt username + mật khẩu qua UI.
#
# Chỉ set INITIAL_ADMIN_PASSWORD khi muốn deploy headless (CI/CD tự seed admin
# không cần người mở UI). Sau đó đăng nhập → đổi mật khẩu → XOÁ và up lại.
# Mật khẩu phải ≥12 ký tự, có ít nhất 3/4 nhóm: thường / hoa / số / đặc biệt.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# ── HTTP / CORS ──────────────────────────────────────────────
# Port host map ra (đổi nếu 3001 bị chiếm).
APP_PORT=3001

# Để TRỐNG nếu frontend cùng host backend (mặc định — backend serve cả frontend).
# Chỉ điền khi gọi API từ origin khác (vd kèm domain reverse proxy):
#   ALLOWED_ORIGINS=https://ketoan.example.com,https://lan.example.local
ALLOWED_ORIGINS=

# Bật HSTS + CSP nghiêm ngặt khi backend nằm sau HTTPS reverse proxy (nginx/caddy).
# LAN HTTP thuần (192.168.x.x) → để 0 để tránh ERR_SSL_PROTOCOL_ERROR.
ENABLE_HSTS=0
