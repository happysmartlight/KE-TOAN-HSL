# Backend environment variables
# Copy file này thành .env và chỉnh sửa nếu cần
# (install.sh sẽ tự tạo .env từ file này)

# Đường dẫn SQLite database (install.sh sẽ tự điền đường dẫn tuyệt đối)
DATABASE_URL="file:./prisma/dev.db"

# JWT secret — đổi thành chuỗi ngẫu nhiên trước khi deploy thật
JWT_SECRET="ke-toan-noi-bo-secret-2024"

# Port backend
PORT=3001
