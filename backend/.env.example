# Backend environment variables
# Copy file này thành .env và chỉnh sửa nếu cần

# Kết nối MariaDB
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://ketoan:ketoan@hsl2025@localhost:3306/ke_toan_noi_bo"

# JWT secret — đổi thành chuỗi ngẫu nhiên trước khi deploy thật
JWT_SECRET="ke-toan-noi-bo-secret-2025"

# Port backend
PORT=3001
