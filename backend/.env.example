# Backend environment variables
# Copy file này thành .env và chỉnh sửa lại cho đúng.
# Khi chạy `bash install.sh`, script sẽ hỏi tương tác (hoặc đọc biến môi trường
# DB_NAME / DB_USER / DB_PASS) và tự ghi đè DATABASE_URL cùng JWT_SECRET bên dưới.

# ── Database ────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Lưu ý: nếu PASSWORD chứa ký tự đặc biệt (@ : / ? # & ...) thì phải URL-encode
# (ví dụ '@' → '%40'). Script install.sh sẽ tự xử lý việc này.
DATABASE_URL="mysql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@localhost:3306/CHANGE_ME_DBNAME"

# ── JWT ─────────────────────────────────────────────────────
# BẮT BUỘC. Chuỗi ngẫu nhiên dài (≥32 ký tự, khuyến nghị 64 hex).
# Sinh nhanh: openssl rand -hex 64
# install.sh tự sinh nếu thấy giá trị "change-me" / để trống.
# KHÔNG chia sẻ và KHÔNG commit giá trị thật vào git.
JWT_SECRET="change-me"

# ── Bootstrap admin (chỉ dùng lần đầu) ──────────────────────
# Khi DB chưa có user nào, server sẽ dùng các biến này để tạo admin đầu tiên.
# Sau khi đăng nhập lần đầu và đổi mật khẩu, HÃY XOÁ 2 biến này khỏi .env.
# Mật khẩu phải ≥12 ký tự, có ít nhất 3/4 nhóm: chữ thường, chữ hoa, số, ký tự đặc biệt.
INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD=""

# ── HTTP server ─────────────────────────────────────────────
# Port backend lắng nghe.
PORT=3001
# Host bind. Mặc định 127.0.0.1 — backend chỉ lắng nghe loopback và phải đặt
# sau reverse proxy (nginx/caddy) để xử lý TLS, rate limit, headers.
# Chỉ đổi sang 0.0.0.0 khi bạn THỰC SỰ cần expose Node trực tiếp ra mạng.
BIND_HOST=127.0.0.1

# ── CORS ────────────────────────────────────────────────────
# Danh sách origin được phép gọi API, cách nhau bằng dấu phẩy.
# Vd: "https://ketoan.example.com,https://ketoan-lan.example.local"
# Để trống → chỉ chấp nhận same-origin (frontend serve cùng host backend).
ALLOWED_ORIGINS=""
