{
  "name": "ke-toan-noi-bo-backend",
  "version": "0.3.5",
  "description": "Internal Accounting System - Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node-dev --transpile-only prisma/seed.ts",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:system": "jest --selectProjects system",
    "test:ci": "jest --ci --runInBand"
  },
  "prisma": {
    "seed": "ts-node-dev --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@types/multer": "^2.1.0",
    "@types/node-cron": "^3.0.11",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
